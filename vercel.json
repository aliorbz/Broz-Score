{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/score/[username].ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/score/(.*)",
      "destination": "/api/score/[username]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
